# ATLAS PUSH -> Atlas Code-Quant vision bridge
# Safe example only. Do not store private production secrets in git.

# Base URL for the quant API.
# Default inside the bridge is http://127.0.0.1:8792
ATLAS_QUANT_API_URL=http://127.0.0.1:8792

# Local placeholder key used by the PUSH bridge when calling Atlas Code-Quant.
# Replace it only if your quant API expects a different shared key.
ATLAS_QUANT_API_KEY=atlas-quant-local

# Optional screen-to-neck calibration used before camera capture.
# Generate it with scripts/atlas_screen_gaze_calibrate.py
ATLAS_SCREEN_GAZE_CALIB_PATH=C:\ATLAS_PUSH\config\screen_gaze_calibration.json
