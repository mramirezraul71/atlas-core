# ============================================================================
# atlas_radar_kalshi — variables de entorno
# Copiar a `.env` (mismo directorio), a C:\ATLAS\config\.env (Windows), o a
#   ~/.atlas/config/.env (Linux/macOS) si esa ruta existe.
#
# Predeterminado en código (sin estas claves): paper virtual + perfil
# paper_aggressive + AutoTune modo auto activo + intervalos cortos.
# Para datos Kalshi PRODUCCIÓN con órdenes PAPER (recomendado operar activo):
#   KALSHI_ENV=prod  +  ATLAS_RADAR_LIVE=0  +  RADAR_PROFILE=paper_aggressive
# ============================================================================

# --- Kalshi -----------------------------------------------------------------
KALSHI_API_KEY=00000000-0000-0000-0000-000000000000
KALSHI_PRIVATE_KEY_PATH=C:\ATLAS\config\kalshi_private.pem
# demo = sandbox API; prod = mercado real (sigue siendo paper si ATLAS_RADAR_LIVE=0)
KALSHI_ENV=prod
# KALSHI_BASE_URL=
# KALSHI_WS_URL=
# RADAR_DISABLE_PUBLIC_MARKET_DATA=0

# --- Ollama (cerebro local) -------------------------------------------------
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
RADAR_OLLAMA_TIMEOUT_S=20

# --- Atlas Core dashboard ---------------------------------------------------
ATLAS_DASHBOARD_URL=http://127.0.0.1:8791

# --- Perfil operativo --------------------------------------------------------
# paper_aggressive | paper_calib | paper_safe | balanced | aggressive
# paper_aggressive = paper + gating permisivo + riesgo alto (predeterminado si omites la variable)
RADAR_PROFILE=paper_aggressive
RADAR_EDGE_THRESHOLD=0.05
RADAR_KELLY_FRACTION=0.25
RADAR_EDGE_NET_MIN=0.03
RADAR_WATCHDOG_STALE_SEC=120
RADAR_WATCHDOG_RECOVER_SEC=180
RADAR_WATCHDOG_RECOVER_COOLDOWN_SEC=90
RADAR_MAX_POSITION_PCT=0.05
RADAR_MC_ITERS=10000

# --- Universo ---------------------------------------------------------------
RADAR_MARKET_STATUS=open
RADAR_POLL_SECONDS=30

# --- Logging ----------------------------------------------------------------
ATLAS_LOG_DIR=C:\ATLAS\logs
RADAR_LOG_LEVEL=INFO

# --- Paper (órdenes virtuales) / Live ---------------------------------------
ATLAS_RADAR_EXECUTION_MODE=paper
ATLAS_RADAR_LIVE=0
RADAR_PAPER_BALANCE_CENTS=1000000

# --- Política de remediación -------------------------------------------------
# 1 = fuerza paper+balanced y bloquea AutoTune en modo auto (instalación cautelosa).
# 0 = permite el stack predeterminado paper_aggressive + AutoTune auto (operación activa).
RADAR_REMEDIATION_POLICY_ENFORCE=0

# --- AutoTune (ajuste automático de umbrales) ---------------------------------
RADAR_AUTOTUNE_MODE=auto
RADAR_AUTOTUNE_ENABLED=1
RADAR_AUTOTUNE_INTERVAL_S=120
RADAR_AUTOTUNE_OBS_S=180

# --- Operador de autonomía (saneo / max_open paper) -------------------------
# RADAR_AUTONOMY_INTERVAL_S=90
# RADAR_AUTONOMY_DISABLE=0
# RADAR_AUTONOMY_LLM=1

# POLYMARKET_ENABLED=0
