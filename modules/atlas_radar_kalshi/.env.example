# ============================================================================
# atlas_radar_kalshi — variables de entorno
# Copiar a `.env` (mismo directorio) o a C:\ATLAS\config\.env
# ============================================================================

# --- Kalshi -----------------------------------------------------------------
# La clave y el PEM también pueden ir solo en la Bóveda (credenciales.txt) como KALSHI_*
KALSHI_API_KEY=00000000-0000-0000-0000-000000000000
KALSHI_PRIVATE_KEY_PATH=C:\ATLAS\config\kalshi_private.pem
KALSHI_ENV=demo                       # demo | prod
# KALSHI_BASE_URL=                    # opcional override REST
# KALSHI_WS_URL=                      # opcional override WS
# Sin UUID+PEM: mercado y libro vía REST público (Kalshi). 1 = exigir credenciales.
# RADAR_DISABLE_PUBLIC_MARKET_DATA=0

# --- Ollama (cerebro local) -------------------------------------------------
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
RADAR_OLLAMA_TIMEOUT_S=20

# --- Atlas Core dashboard ---------------------------------------------------
ATLAS_DASHBOARD_URL=http://127.0.0.1:8791

# --- Risk & Edge ------------------------------------------------------------
# Perfil operativo: paper_safe | balanced | aggressive
# (las variables RADAR_* explícitas siempre tienen prioridad sobre el perfil)
# Default en este ejemplo: balanced (validación paper alineada con LIVE_GATE_CHECKLIST).
RADAR_PROFILE=balanced
RADAR_EDGE_THRESHOLD=0.05             # 5 puntos de probabilidad
RADAR_KELLY_FRACTION=0.25             # quarter-Kelly
RADAR_EDGE_NET_MIN=0.03               # edge neto mín. tras costos (gating); editable en /ui/radar
# Sin eventos del feed más de N s → UI "DEGRADED" (no bloquea órdenes por sí solo)
RADAR_WATCHDOG_STALE_SEC=120
# Autocuración: si sigue stale, watchdog fuerza recover del scanner.
RADAR_WATCHDOG_RECOVER_SEC=180
RADAR_WATCHDOG_RECOVER_COOLDOWN_SEC=90
# Gating (paper/REST: antes spread=99 y quote_age por cola bloqueaban todo)
# RADAR_SPREAD_MAX=8
# RADAR_MIN_DEPTH_YES=12
# RADAR_MIN_DEPTH_NO=12
# RADAR_MAX_QUOTE_AGE_MS=20000
# Fallback: eventos ticker sintéticos desde /markets por ciclo (anti-silencio)
# RADAR_MARKET_TICKER_EMIT_MAX=120
# Si sigue sin pasar gating: probar RADAR_CONFIDENCE_MIN=0.52 (más permisivo)
RADAR_MAX_POSITION_PCT=0.05
RADAR_MC_ITERS=10000

# --- Universo ---------------------------------------------------------------
RADAR_MARKET_STATUS=open
RADAR_POLL_SECONDS=30

# --- Logging ----------------------------------------------------------------
ATLAS_LOG_DIR=C:\ATLAS\logs
RADAR_LOG_LEVEL=INFO

# --- Modo paper (datos reales de mercado, órdenes virtuales) + paso a live
# Ajusta el capital simulado (centavos): 1_000_000 = 10_000 USD virtuales
ATLAS_RADAR_EXECUTION_MODE=paper
ATLAS_RADAR_LIVE=0
RADAR_PAPER_BALANCE_CENTS=1000000
# Política de remediación (1 = forzar paper+balanced y bloquear autotune auto).
# Recomendado 1 para clonar el repo y validar sin sorpresas; pon 0 solo si ya
# supervisas autotune auto y aceptas el riesgo (p. ej. laboratorio controlado).
RADAR_REMEDIATION_POLICY_ENFORCE=1
# Autotune: manual = el operador aplica parches; assisted/auto requieren disciplina.
# Intervalos largos reducen oscilación de config antes de tener track record.
RADAR_AUTOTUNE_MODE=manual
RADAR_AUTOTUNE_ENABLED=1
RADAR_AUTOTUNE_INTERVAL_S=900
RADAR_AUTOTUNE_OBS_S=1800

# --- Opcional: modo agresivo solo para desarrollo / stress en paper -----------
# NO copiar tal cual antes de cerrar hallazgos abiertos de auditoría ni para live.
# RADAR_PROFILE=aggressive
# RADAR_REMEDIATION_POLICY_ENFORCE=0
# RADAR_AUTOTUNE_MODE=auto
# RADAR_AUTOTUNE_INTERVAL_S=120
# RADAR_AUTOTUNE_OBS_S=180
# Polymarket: variable reconocida si el build incluye multi-venue
# POLYMARKET_ENABLED=0
