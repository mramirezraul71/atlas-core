# ============================================================================
# atlas_radar_kalshi — variables de entorno
# Copiar a `.env` (mismo directorio) o a C:\ATLAS\config\.env
# ============================================================================

# --- Kalshi -----------------------------------------------------------------
KALSHI_API_KEY=00000000-0000-0000-0000-000000000000
KALSHI_PRIVATE_KEY_PATH=C:\ATLAS\config\kalshi_private.pem
KALSHI_ENV=demo                       # demo | prod
# KALSHI_BASE_URL=                    # opcional override REST
# KALSHI_WS_URL=                      # opcional override WS

# --- Ollama (cerebro local) -------------------------------------------------
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# --- Atlas Core dashboard ---------------------------------------------------
ATLAS_DASHBOARD_URL=http://127.0.0.1:8791

# --- Risk & Edge ------------------------------------------------------------
RADAR_EDGE_THRESHOLD=0.05             # 5 puntos de probabilidad
RADAR_KELLY_FRACTION=0.25             # quarter-Kelly
RADAR_MAX_POSITION_PCT=0.05
RADAR_MC_ITERS=10000

# --- Universo ---------------------------------------------------------------
RADAR_MARKET_STATUS=open
RADAR_POLL_SECONDS=30

# --- Logging ----------------------------------------------------------------
ATLAS_LOG_DIR=C:\ATLAS\logs
RADAR_LOG_LEVEL=INFO
