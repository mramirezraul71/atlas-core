# ============================================================================
# atlas_radar_kalshi — variables de entorno
# Copiar a `.env` (mismo directorio), C:\ATLAS\config\.env, o ~/.atlas/config/.env
#
# Predeterminado en código (sin RADAR_PROFILE): paper_public_rest + AutoTune auto.
# paper_public_rest = feed REST público Kalshi (depth bajo, spreads amplios en demo).
# Para prod real con órdenes paper y mejor libro: KALSHI_ENV=prod + claves válidas.
# ============================================================================

# --- Kalshi -----------------------------------------------------------------
KALSHI_API_KEY=00000000-0000-0000-0000-000000000000
KALSHI_PRIVATE_KEY_PATH=C:\ATLAS_NEXUS\atlas-core\secrets\kalshi_private.pem
KALSHI_ENV=demo
RADAR_DISABLE_PUBLIC_MARKET_DATA=0

# --- LLM --------------------------------------------------------------------
RADAR_LLM_BACKEND=ollama
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
RADAR_OLLAMA_TIMEOUT_S=5
RADAR_BRAIN_FALLBACK_OLLAMA=1

# --- Logging ----------------------------------------------------------------
ATLAS_LOG_DIR=C:\ATLAS_NEXUS\atlas-core\logs
RADAR_LOG_LEVEL=INFO

# --- Perfil operativo -------------------------------------------------------
# paper_public_rest | paper_calib | paper_aggressive | balanced | aggressive
RADAR_PROFILE=paper_public_rest

RADAR_SPREAD_MAX=95
RADAR_MIN_DEPTH_YES=1
RADAR_MIN_DEPTH_NO=1
RADAR_MAX_QUOTE_AGE_MS=120000
RADAR_MAX_LATENCY_MS=5000
RADAR_EDGE_NET_MIN=0.020
RADAR_CONFIDENCE_MIN=0.32
RADAR_COOLDOWN_S=15

# Paper: DD y rachas algo más realistas que 0.95/999 (sigue permisivo vs live)
RADAR_DAILY_DD=0.40
RADAR_WEEKLY_DD=0.58
RADAR_MAX_CL=16
RADAR_MAX_OPEN=13
RADAR_MAX_OPM=22

RADAR_MARKET_STATUS=open
RADAR_POLL_SECONDS=20

RADAR_WATCHDOG_STALE_SEC=180
RADAR_WATCHDOG_RECOVER_SEC=240
RADAR_WATCHDOG_RECOVER_COOLDOWN_SEC=90

RADAR_JOURNAL_ALL_DECISIONS=1

# --- Paper / Live -------------------------------------------------------------
ATLAS_RADAR_EXECUTION_MODE=paper
ATLAS_RADAR_LIVE=0
ATLAS_RADAR_KILL=0
RADAR_PAPER_BALANCE_CENTS=1000000

RADAR_REMEDIATION_POLICY_ENFORCE=0

RADAR_AUTOTUNE_MODE=auto
RADAR_AUTOTUNE_ENABLED=1
RADAR_AUTOTUNE_INTERVAL_S=135
RADAR_AUTOTUNE_OBS_S=180

# --- Atlas Core dashboard ---------------------------------------------------
ATLAS_DASHBOARD_URL=http://127.0.0.1:8791

# Opcionales legacy / tuning
# RADAR_EDGE_THRESHOLD=0.05
# RADAR_KELLY_FRACTION=0.25
# RADAR_MC_ITERS=10000
