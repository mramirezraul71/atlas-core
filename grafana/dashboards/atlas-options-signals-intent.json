{
  "uid": "atlas-options-signals-intent",
  "title": "Options Engine — Signals & Intent",
  "description": "Options flow (atlas_options_flow_*) y VisualSignalAdapter (atlas_options_visual_signal_state). IV rank quality, self-audit y sentinelas explícitos están en dashboard Health (atlas-options-health).",
  "tags": ["atlas", "options", "paper", "signals", "intent", "flow", "visual"],
  "timezone": "UTC",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 201,
      "title": "S-01 Flow payload disponible (1=coherente, 0=ausente/incompleto)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "atlas-prom"},
          "expr": "atlas_options_flow_payload_available",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 202,
      "title": "S-02 Put/call volumen (ratio; -1 = sin dato)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "atlas-prom"},
          "expr": "atlas_options_flow_put_call_volume_ratio",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none"}}
    },
    {
      "id": 203,
      "title": "S-03 Gamma bias % (-1 = sin dato)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 7},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "atlas-prom"},
          "expr": "atlas_options_flow_gamma_bias_pct",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "decimals": 2}}
    },
    {
      "id": 204,
      "title": "S-04 Flow score % (-1 = sin dato)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 7},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "atlas-prom"},
          "expr": "atlas_options_flow_score_pct",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "min": -1, "max": 100, "decimals": 1}}
    },
    {
      "id": 205,
      "title": "S-05 Flow confidence % (0 si payload no coherente)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 7},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "atlas-prom"},
          "expr": "atlas_options_flow_confidence_pct",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 100, "decimals": 1}}
    },
    {
      "id": 206,
      "title": "S-06 Visual signal state (0 error, 0.2 sin input, 0.5 ok, 0.75 breach, 1.0 crítico)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 14},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "atlas-prom"},
          "expr": "atlas_options_visual_signal_state",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "yellow", "value": 0.45},
              {"color": "red", "value": 0.85}
            ]
          }
        }
      }
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []}
}
