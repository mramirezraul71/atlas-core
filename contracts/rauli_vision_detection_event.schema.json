{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RAULI-VISION Detection Event",
  "type": "object",
  "required": [
    "event_id",
    "source",
    "timestamp_iso",
    "detections"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 8
    },
    "source": {
      "type": "string",
      "const": "rauli-vision"
    },
    "timestamp_iso": {
      "type": "string"
    },
    "camera_id": {
      "type": "string"
    },
    "store_id": {
      "type": "string"
    },
    "anomaly": {
      "type": "object",
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "detections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "product_id",
          "count"
        ],
        "properties": {
          "product_id": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "count": {
            "type": "number"
          },
          "quality_score": {
            "type": "number"
          },
          "confidence": {
            "type": "number"
          },
          "action_hint": {
            "type": "string",
            "enum": [
              "entrada",
              "salida",
              "ajuste",
              "merma"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
