# ============================================================
# ATLAS — .env generado desde Bóveda (C:\dev\credenciales.txt)
# ============================================================
# Generar con: python scripts/sync_env_from_vault.py
# NO commitear este archivo (está en .gitignore).
# ============================================================

# Bóveda (origen de API keys)
ATLAS_VAULT_PATH=C:\dev\credenciales.txt

# Ollama (modelos locales)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-r1:latest
OLLAMA_MODEL_FAST=llama3.2:3b
OLLAMA_MODEL_CHAT=llama3.1:latest
OLLAMA_MODEL_CODE=deepseek-coder:6.7b
OLLAMA_MODEL_REASON=deepseek-r1:14b
OLLAMA_MODEL_TOOLS=qwen2.5:7b

# APIs externas (se rellenan desde credenciales.txt al ejecutar sync_env_from_vault.py)
# OPENAI_API_KEY=
# OPENAI_CODEX_MODEL=gpt-4.1-mini
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=
# PERPLEXITY_API_KEY=

# Permitir uso de APIs externas en ATLAS (true = usar tus keys)
AI_ALLOW_EXTERNAL_APIS=true

# Modelos por ruta (formato provider:model)
AI_FAST_MODEL=ollama:llama3.2:3b
AI_CHAT_MODEL=ollama:llama3.1:latest
AI_CODE_MODEL=ollama:deepseek-coder:6.7b
AI_REASON_MODEL=ollama:deepseek-r1:14b
AI_TOOLS_MODEL=ollama:qwen2.5:7b
AI_VISION_MODEL=ollama:llama3.2-vision:11b
AI_ARCHITECT_MODEL=ollama:deepseek-r1:14b
AI_OPTIMIZER_MODEL=ollama:deepseek-coder:6.7b

# Cline / Cursor: usar esta infraestructura (no crédito del editor)
# Configurar en Cursor: Settings → Cline → API Keys from env
# O Settings → Features → Use custom API / Own API keys
CREDENTIALS_FILE=C:\dev\credenciales.txt

# ANS Engine — Backoff entre heals del mismo tipo (segundos). 0 = desactivado.
ANS_HEAL_BACKOFF_SEC=300
