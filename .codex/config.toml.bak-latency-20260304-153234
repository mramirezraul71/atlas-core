# ATLAS_PUSH project config (canonical + valid for Codex CLI 0.106.x)
# Fallback strategy: keep this file identical to global config to avoid precedence conflicts.

model = "gpt-5.3-codex"
model_reasoning_effort = "xhigh"
model_verbosity = "high"
approval_policy = "never"
sandbox_mode = "danger-full-access"
web_search = "live"
show_raw_agent_reasoning = true

[windows]
sandbox = "elevated"

[features]
shell_snapshot = true

[profiles.atlas_supervisor]
model = "gpt-5.3-codex"
model_reasoning_effort = "xhigh"
model_verbosity = "high"
approval_policy = "never"
sandbox_mode = "danger-full-access"
web_search = "live"
show_raw_agent_reasoning = true

[profiles.atlas_safe]
model = "gpt-5.3-codex"
model_reasoning_effort = "high"
model_verbosity = "medium"
approval_policy = "on-request"
sandbox_mode = "workspace-write"
web_search = "live"
show_raw_agent_reasoning = false

[mcp_servers.figma]
url = "https://mcp.figma.com/mcp"
